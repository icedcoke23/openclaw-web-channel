{
  "name": "openclaw-web-channel",
  "version": "3.0.0",
  "description": "Production-grade web dashboard for OpenClaw AI assistant gateway",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx nodemon server.js",
    "dev:frontend": "cd client && npm run dev",
